VITE_API_BASE_URL=https://coms.kw.ac.kr/api

# Sentry error reporting (optional — leave VITE_SENTRY_DSN blank to disable).
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production

# --- Sentry source map upload (optional, for readable stack traces) ---
# Source maps are uploaded ONLY when SENTRY_AUTH_TOKEN is non-empty at build
# time. Leave it blank for normal/dev builds (the @sentry/vite-plugin is
# skipped, nothing is uploaded, the build still succeeds).
# To actually upload readable stack traces, set all three:
#   - SENTRY_AUTH_TOKEN: a Sentry org auth token with project:releases scope
#     (Sentry -> Settings -> Auth Tokens). REQUIRED to trigger upload.
#   - SENTRY_ORG:     Sentry org slug   (defaults to "kw-coms" in vite.config.js)
#   - SENTRY_PROJECT: Sentry project slug (defaults to "coms-member-app")
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kw-coms
SENTRY_PROJECT=coms-member-app
